{
  "appId": "app.futurega.me",
  "appName": "futurega.me",
  "webDir": "public",
  "server": {
    "allowNavigation": ["futurega.me"]
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#111111",
    "preferredContentMode": "mobile"
  },
  "android": {
    "backgroundColor": "#111111"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#111111",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#111111"
    }
  }
}
