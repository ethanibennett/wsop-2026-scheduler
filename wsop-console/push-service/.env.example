# Copy this to .env and fill in.

# Generate these once with:  npm run keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# A contact URI Apple/push services can reach. Your email is fine.
VAPID_SUBJECT=mailto:you@example.com

# Port the server listens on.
PORT=3000

# Your timezone — the schedule's cron times run in this zone.
# e.g. America/New_York for Philadelphia.
TZ=America/New_York
